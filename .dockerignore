# Never let a local .env (or other local secrets) leak into the build context/image
.env
.env.*
!.env.example

# Local dev/build artifacts — rebuilt fresh inside the image
node_modules
.nuxt
.output
.data
.cache
dist

# VCS / editor / OS cruft
.git
.gitignore
.DS_Store
.idea
.fleet

# Raw asset sources not needed at runtime
*.mov
*.blend
Renderlar
